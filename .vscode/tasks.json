{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Django backend",
			"type": "shell",
			"command": "${workspaceFolder}\\.venv-2\\Scripts\\python.exe",
			"args": [
				"backend/manage.py",
				"runserver"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Run React frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"start"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Run React frontend (Admin Port 3001)",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"run",
				"start:admin"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Install frontend deps",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"install"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Install frontend deps (legacy peer deps)",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"install",
				"--legacy-peer-deps"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Install frontend deps (legacy peer deps)",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"install",
				"--legacy-peer-deps",
				"--no-fund",
				"--no-audit"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}